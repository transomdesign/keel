# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# Current Craft environment (dev || staging || production)
CRAFT_ENVIRONMENT=dev

# General settings
CRAFT_SYSTEM_NAME=Keel
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true
CRAFT_RUN_QUEUE_AUTOMATICALLY=true
CRAFT_ALLOW_UPDATES=true

# Database connection settings
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=db
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=db
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db
CRAFT_DB_SCHEMA=public

# Makefile: remote server settings (for make db-pull / make db-push-staging)
# Fill these in once the project is deployed — not needed for local dev.
MAKE_PROD_USER=forge
MAKE_PROD_HOST=
MAKE_PROD_PATH=

MAKE_STAGING_USER=forge
MAKE_STAGING_HOST=
MAKE_STAGING_PATH=
MAKE_STAGING_DB_USER=forge
MAKE_STAGING_DB_NAME=keel_staging
MAKE_STAGING_DB_PASSWORD=

# Custom Settings (Not Official Craft)
# (no trailing slash, please)
URL_PRIMARY=https://keel.ddev.site
URL_SECONDARY=https://keel-secondary.ddev.site
URL_TERTIARY=https://keel-tertiary.ddev.site
URL_FOURTH=https://keel-fourth.ddev.site

# DigitalOcean Spaces settings
# See: https://cloud.digitalocean.com → Spaces → Access Keys
DO_SPACES_API_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_BASE_URL=https://keel.sfo3.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=keel
DO_SPACES_SUBDIR=

# Google reCAPTCHA (Enterprise)
GOOGLE_CONSOLE_API_KEY=
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_CLOUD_PROJECT_ID=

# Postmark
POSTMARK_SERVER_TOKEN=
