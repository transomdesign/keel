{
  "name": "keel",
  "type": "module",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "prebuild": "bun run clean && bun run type-check",
    "type-check": "tsc --noEmit",
    "build": "bun ./node_modules/vite/bin/vite.js build",
    "clean": "rimraf web/hot web/dist/* web/*.{ico,png,svg,xml,webmanifest} web/{,**/}*{html,json}",
    "lint": "eslint . --ext .ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@epic-web/config": "^3.1.0",
    "@prettier/plugin-php": "^0.25.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@zackad/prettier-plugin-twig": "^0.17.0",
    "chokidar": "^5.0.0",
    "eslint": "^10.4.0",
    "fs-extra": "^11.3.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-gzip": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dev-urls": "^0.1.0",
    "vite-plugin-live-reload": "^3.1.0",
    "vite-plugin-restart": "^2.0.0",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "dependencies": {
    "@a11y/focus-trap": "^1.0.5",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "@splidejs/splide": "^4.1.4",
    "@splidejs/splide-extension-auto-scroll": "^0.5.3",
    "body-scroll-lock": "^4.0.0-beta.0",
    "focus-trap": "^8.2.1"
  }
}
