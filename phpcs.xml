<?xml version="1.0"?>
<ruleset name="Custom">
    <description>Custom coding standard for this project</description>
    
    <!-- Include PSR-12 standard (much more reasonable than PEAR) -->
    <rule ref="PSR12"/>
    
    <!-- Allow longer line lengths -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="140"/>
        </properties>
    </rule>
    
    <!-- Disable some overly strict rules -->
    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
        <exclude-pattern>*/config/*</exclude-pattern>
    </rule>
    
    <!-- Don't require file-level docblocks for config files -->
    <rule ref="Squiz.Commenting.FileComment.Missing">
        <exclude-pattern>*/config/*</exclude-pattern>
    </rule>
</ruleset>
