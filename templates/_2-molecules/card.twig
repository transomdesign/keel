<!-- Template: {{ _self }} -->

{% set id = id|default %}
{% set richText = richText|default %}
{% set rating = rating|default %}
{% set ratingIsEnabled = ratingIsEnabled|default %}
{% set theme = theme|default %}
{% set classes = classes|default %}

{% if richText is not empty %}
	{% tag 'div'
		with
		{
			id: 'card-' ~ id,
			class: ['card passage', classes]
		}
	%}
		{% if ratingIsEnabled and rating is not empty %}
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 136 27"
				width="136"
				height="27"
				class="mb-3"
			>
				<title>
					Rating {{ rating }} out of 5
				</title>

				<style>
					:scope #mask-{{ id }} rect { --rating: {{ rating }}; /* Your rating
					value from 1-5 */ transform: translateX(calc(-100% + (var(--rating) /
					5 * 100%))); }
				</style>

				<defs>
					<mask id="mask-{{ id }}">
						<rect width="136" height="27" fill="#fff" />
					</mask>

					<symbol id="circles-{{ id }}">
						<circle cx="124" cy="13.5" r="9.5" />
						<circle cx="96" cy="13.5" r="10" />
						<circle cx="68" cy="13.5" r="10" />
						<circle cx="40" cy="13.5" r="10" />
						<circle cx="12" cy="13.5" r="10" />
					</symbol>
				</defs>

				<g fill="none" stroke="currentColor">
					<use href="#circles-{{ id }}" />
				</g>

				<g mask="url(#mask-{{ id }})">
					<g fill="currentColor" stroke="currentColor">
						<use href="#circles-{{ id }}" />
					</g>
				</g>
			</svg>
		{% endif %}

		{{ richText }}
	{% endtag %}
{% endif %}
