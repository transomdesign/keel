<!-- Template: {{ _self }} -->

{% set id = id|default %}
{% set width = width|default('section--narrow') %}
{% set mt = mt|default %}
{% set classes = classes|default %}
{% set richText = richText|default %}
{% set section = section|default(null) %}
{% set theme = theme is defined ? (theme.value ?? theme)|default('white') : 'white' %}

{% set containerAttr = {
	id: id,
	class: ['section', width, classes]
} %}

{% embed '_2-molecules/section-theme' with { theme, mt } %}
	{% block content %}
		<div {{ attr(containerAttr) }}>
			<div class="text-block">
				{% if richText %}
					<article class="passage">{{ richText }}</article>
				{% endif %}
			</div>
		</div>
	{% endblock %}
{% endembed %}
