<!-- Template: {{ _self }} -->

{% set siteSettings = siteSettings ?? null %}
{% set logoDesktop = siteSettings ? siteSettings.headerLogoDesktop.one() : null
%}
{% set logoMobile = siteSettings ? siteSettings.headerLogoMobile.one() : null %}
{% set navNodes = craft.navigation.nodes('main').all() %}
{% set toolboxNodes = craft.navigation.nodes('toolbox').level(1).all() %}

<nav id="navbar" class="navbar" aria-label="Main">
	<div class="navbar__content-wrap">
		<div class="navbar__content">
			{# Navbar: Left side #}
			<div class="navbar__content-links">
				{% include '_1-atoms/navbar-hamburger-button.twig' %}

				{# Navigation → Main #}
				{% if navNodes is not empty %}
					<menu class="navbar__links">
						{% nav node in navNodes %}
							<li>
								{{ node.link }}

								{% ifchildren %}
									<ul>
										{% children %}
									</ul>
								{% endifchildren %}
							</li>
						{% endnav %}
					</menu>
				{% endif %}
			</div>

			{# Navbar: Middle (Logo) #}
			{# See: Site Settings → Header Logo Desktop / Header Logo Mobile #}
			{% if logoDesktop is not empty or logoMobile is not empty %}
				<a
					class="navbar__logo"
					href="/"
					aria-label="{{ currentSite.name }} Homepage"
				>
					{% if logoDesktop is not empty %}
						{{
							svg(logoDesktop)|attr({
								class: 'navbar__logo-desktop',
								width: false,
								height: false
							})
						}}
					{% endif %}
					{% if logoMobile is not empty %}
						{{
							svg(logoMobile)|attr({
								class: 'navbar__logo-mobile',
								width: false,
								height: false
							})
						}}
					{% endif %}
				</a>
			{% endif %}

			{# Navbar: Right side — only rendered when the toolbox nav has nodes #}
			{% if toolboxNodes is not empty %}
				<div class="navbar__content-tools">
					<div class="toolbox">
						<button
							class="toolbox-trigger"
							aria-expanded="false"
							aria-controls="toolbox-menu"
							aria-label="Toolbox links"
							type="button"
						>
						  <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 30 30">
						    <path fill="currentColor" d="M24 22.5q1 0 1-1v-3q0-1-1-1h-2.1q-.6 0-.6.6t-.7.6h-1.2l-.6-.6q0-.5-.7-.6H12q-.6 0-.7.6t-.6.6H9.4a.6.6 0 0 1-.7-.6q0-.5-.6-.6H6a1 1 0 0 0-1 1v3q0 1 1 1zM8.6 10a1 1 0 0 0-1 .6l-1.3 3a1 1 0 0 0 1 1.4H8q.7 0 .7-.6t.6-.7h1.2q.6 0 .7.7 0 .5.6.6H18q.6 0 .6-.6t.7-.7h1.2q.6 0 .6.7 0 .5.7.6h.8a1 1 0 0 0 1-1.4l-1.4-3a1 1 0 0 0-.9-.6zm3.3-3.7a.6.6 0 1 0 0 1.2H18a.6.6 0 1 0 0-1.2zm15.4 9.5.2 1v5.7q0 1-.7 1.8-.8.7-1.8.7H5q-1 0-1.7-.7-.8-.8-.8-1.8v-5.7q0-.6.2-1l3-6.8q.5-1.5 2.2-1.5.8-.1.8-.8v-.5q0-1 .8-1.7.6-.7 1.8-.7h7.5q1 0 1.7.7.8.7.8 1.8v.4q0 .7.8.8 1.5 0 2.3 1.5z"/>
							 </svg>
							<span class="toolbox-trigger__label">Toolbox</span>
						</button>

						<div id="toolbox-menu" class="toolbox-menu" aria-expanded="false">
							<div class="toolbox-menu__inner">
								<ul class="toolbox-menu__links" role="list">
									{% for node in toolboxNodes %}
										<li>
											<a
												href="{{ node.url }}"
												class="toolbox-menu__link"
												{% if node.target %}target="{{ node.target }}" rel="noopener"{% endif %}
											>{{ node.title }}</a>
										</li>
									{% endfor %}
								</ul>
							</div>
						</div>
					</div>
				</div>
			{% endif %}
		</div>
	</div>
</nav>
