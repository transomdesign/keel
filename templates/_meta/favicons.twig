<!-- Template: {{ _self }} -->

{# -- Favicons -- #}
{# -- See: https://evilmartians.com/chronicles/how-to-favicon-in-2021-six-files-that-fit-most-needs -#}
{% set settings = siteSettings ?? craft.entries.section('siteSettings').one() %}

{% if settings %}
	{# Prepare Asset URLs #}
	{% set favicons = settings.favicons %}
	{% set appleTouchIcon = favicons.appleTouchIcon.one() %}
	{% set faviconIco = favicons.ico.one() %}
	{% set faviconSvg = favicons.svg.one() %}

	{# 1. Modern SVG Icon #}
	{% if faviconSvg %}
		<link rel="icon" type="image/svg+xml" href="{{ faviconSvg.url }}" />
	{% endif %}

	{# 2. Legacy Fallback (ICO) #}
	{% if faviconIco %}
		<link rel="icon" href="{{ faviconIco.url }}" sizes="32x32" />
	{% endif %}

	{# 3. Apple Touch Icon #}
	{% if appleTouchIcon %}
		<link rel="apple-touch-icon" href="{{ appleTouchIcon.url }}" />
	{% endif %}

	{# 4. Dynamic Web Manifest #}
	{# --
	   To make /site.webmanifest work, go to Settings → Routes in Craft and add:
       - URI: site.webmanifest
       - Template: site.webmanifest
	#}
	<link rel="manifest" href="/site.webmanifest" />
{% endif %}
