{
	"extends": ["@epic-web/config/typescript"],
	"include": ["src/**/*.ts", "/src/**/*.tsx", "/src/**/*.js", "src/**/*.jsx", "vite.config.ts"],
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"lib": ["esnext", "dom"],
		"types": ["vite/client"],
		"paths": {
			"#src/*": ["./src/*"]
		}
	}
}
